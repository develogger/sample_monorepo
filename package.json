{
  "name": "@zarinpal/repo",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "nx run-many -t lint",
    "clean": "nx run-many -t clean && rimraf dist node_modules",
    "prepare": "is-ci || husky install",
    "format": "prettier -w --cache .",
    "tsc": "nx run-many -t tsc",
    "dev": "nx run shell:dev",
    "codegen": "nx run shell:codegen",
    "dev:kyc": "nx run kyc:dev",
    "story": "nx run docs:story",
    "build": "nx run-many -t build",
    "generate": "nx run locale:generate",
    "release": "nx run-many -t release --parallel=false",
    "release-dry": "nx run-many -t release-dry --parallel=false"
  },
  "private": true,
  "dependencies": {
    "@nx/devkit": "^17.0.3",
    "@sentry/vite-plugin": "^2.10.2",
    "@types/moment-jalaali": "^0.7.9",
    "eslint-plugin-storybook": "^0.6.15"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^18.1.0",
    "@jscutlery/semver": "^4.0.0",
    "@types/lodash-es": "^4.17.9",
    "@typescript-eslint/parser": "~6.10.0",
    "@vee-validate/zod": "^4.11.7",
    "@vue/tsconfig": "^0.4.0",
    "@zarinpal/eslint-config-custom": "workspace:*",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "eslint": "^8.53.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "flag-icons": "^6.7.0",
    "husky": "^8.0.3",
    "is-ci": "^3.0.1",
    "lodash-es": "^4.17.21",
    "moment-jalaali": "^0.10.0",
    "nx": "17.0.3",
    "postcss-import": "^15.1.0",
    "postcss-nesting": "^12.0.1",
    "prettier": "^3.0.3",
    "sharp": "^0.32.6",
    "standard-version": "^9.5.0",
    "storybook": "^7.5.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vee-validate": "^4.11.7",
    "vite-plugin-eslint": "^1.8.1",
    "vite-svg-loader": "^4.0.0",
    "vue-tsc": "^1.8.22",
    "vue3-dropzone": "^2.1.2"
  }
}
