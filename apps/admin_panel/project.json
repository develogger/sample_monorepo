{
  "name": "shell",
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "sourceRoot": "apps/shell/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["locale-generate"],
      "options": {
        "commands": [
          "nuxi build",
          "npx copyfiles -u 1 .output/**/* ../../dist/apps/shell",
          "npx copyfiles -u 1 .nuxt/**/* ../../dist/apps/shell",
          "npx ncp .output ../../dist/apps/shell/.output",
          "npx ncp .nuxt ../../dist/apps/shell/.nuxt",
          "npx rimraf .output"
        ],
        "cwd": "apps/shell",
        "parallel": false
      },
      "configurations": {
        "production": {}
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nuxi dev -p 5000", "graphql-codegen --watch"],
        "cwd": "apps/shell"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["graphql-codegen"],
        "cwd": "apps/shell"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nuxt preview",
        "cwd": "dist/apps/shell"
      }
    },
    "tsc": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shell",
        "commands": ["tsc -p tsconfig.json --noEmit", "vue-tsc --noEmit"]
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shell",
        "commands": ["eslint . --fix"]
      }
    },
    "release": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "push": true,
        "preset": "conventional",
        "tagPrefix": "{projectName}@"
      }
    },
    "release-dry": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "dryRun": true,
        "preset": "conventional",
        "tagPrefix": "{projectName}@"
      }
    }
  },
  "tags": []
}
